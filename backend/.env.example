# Django core
DEBUG=True
SECRET_KEY=

# Allowed hosts (comma-separated)
# Production: .onrender.com,your-custom-domain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS allowed origins (comma-separated)
# Production: https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000

# CSRF trusted origins (comma-separated)
# Production: https://your-backend.onrender.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Public URL for building absolute URLs (e.g., media URLs in local mode)
# Production: https://your-backend.onrender.com
PUBLIC_URL=http://localhost:8000

# Database - Option 1: DATABASE_URL (used by Supabase/Render)
# Production: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Database - Option 2: individual vars (used when DATABASE_URL is empty)
DB_ENGINE=django.db.backends.postgresql
DB_HOST=host.docker.internal
DB_PORT=5433
DB_DATABASE=library_card
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Media storage backend: "local" (default) or "supabase"
MEDIA_STORAGE_BACKEND=local

# Supabase (required when MEDIA_STORAGE_BACKEND=supabase)
# Same Supabase project used for both database and storage
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=media
SUPABASE_S3_REGION=eu-central-1

# On-demand ISR revalidation (optional)
# Production: https://your-frontend.vercel.app/api/revalidate
REVALIDATION_URL=
# Shared secret - must match REVALIDATION_SECRET on Vercel
REVALIDATION_SECRET=
